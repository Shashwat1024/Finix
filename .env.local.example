# Copy this to .env.local and fill in your values

# Supabase — get from https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# NewsAPI — https://newsapi.org/register (free tier)
NEWSAPI_KEY=your-newsapi-key

# Optional: Finnhub for stock data — https://finnhub.io
FINNHUB_KEY=your-finnhub-key

# Resend — for email newsletter reports — https://resend.com
RESEND_API_KEY=your-resend-api-key
# Leave blank to use Resend's test address, or set a verified domain sender
RESEND_FROM=FinAgent <you@yourdomain.com>
